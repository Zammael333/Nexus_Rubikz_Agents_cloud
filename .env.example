# NEXUS-RUBYKZ — Environment Template (OPSEC Blindado)
# Copy to .env.{dev,staging,production} and fill placeholders.
# WARNING: Never commit real credentials. Use Secret Manager in production.
# All values below are ANONYMIZED placeholders — no real project IDs,
# API keys, or endpoint IPs are present in this template.

# ── GCP ────────────────────────────────────────────────────────────────
PROJECT_ID=your-gcp-project-id-anon
LOCATION=us-central1

# ── Model Router (Hybrid Cloud Circuit Breaker) ─────────────────────────
PRIMARY_MODEL=gemini-2.0-flash-001
FALLBACK_MODEL=gemini-1.5-pro-002
ROUTER_STRATEGY=hybrid
VERTEX_API_KEY=your-vertex-api-key-here

# ── Agent Runtime ──────────────────────────────────────────────────────
AGENT_RUNTIME_TARGET=agent_runtime

# ── SPIFFE/SPIRE Identity ──────────────────────────────────────────────
SPIFFE_ENDPOINT_SOCKET=/run/spire/agent/api.sock
SPIFFE_TRUST_DOMAIN=your-trust-domain.example

# ── OpenTelemetry ──────────────────────────────────────────────────────
OTEL_SERVICE_NAME=nexus-rubykz
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_LOG_LEVEL=DEBUG

# ── Database ───────────────────────────────────────────────────────────
# SQLite (dev):   sqlite:///nexus_vault.db
# PostgreSQL (prod): postgresql+asyncpg://user@host/dbname
DATABASE_URL=sqlite:///nexus_vault.db

# ── Async Event Bus ────────────────────────────────────────────────────
BUS_FLUSH_INTERVAL=2.0
BUS_BACKPRESSURE_LIMIT=5000

# ── Budget Watchdog (SLO 99.9973%) ─────────────────────────────────────
SLO_TARGET=99.9973
SLO_WINDOW_HOURS=720
ERROR_BUDGET_MAX=0.0027
BUDGET_WATCHDOG_ALERT_THRESHOLD=0.50
BUDGET_WATCHDOG_FREEZE_THRESHOLD=1.00

# ── Phoenix Protocol (RTO < 2.5s) ──────────────────────────────────────
PHOENIX_RTO_TARGET_SECONDS=2.5
PHOENIX_HEALTH_CHECK_INTERVAL=1.0

# ── Semantic Watchdog ──────────────────────────────────────────────────
# Sensitivity levels: low | medium | high | maximum
WATCHDOG_SENSITIVITY=medium
